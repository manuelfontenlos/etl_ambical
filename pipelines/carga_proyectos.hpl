    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>staging_ambical</connection>
    <execute_each_row>N</execute_each_row>
    <limit>0</limit>
    <sql>SELECT DISTINCT 
    v.id_proyecto, 
    p.tipo_proyecto, 
    p.descripcion_proyecto
FROM staging_productos_ean p
JOIN staging_valoraciones v 
  ON p.id_muestra = v.id_muestra;</sql>
    <variables_active>Y</variables_active>
    <attributes/>
    <GUI>
      <xloc>96</xloc>
      <yloc>144</yloc>
    </GUI>
